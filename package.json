{
  "name": "nexu-design",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "electron-winstaller", "esbuild"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.30.0",
    "knip": "^6.2.0"
  },
  "scripts": {
    "dev": "sh -c 'pnpm --filter @nexu-design/storybook storybook & pnpm --filter @nexu-design/demo dev & wait'",
    "dev:slark": "pnpm --filter slark dev",
    "dev:storybook": "pnpm --filter @nexu-design/storybook storybook",
    "dev:demo": "pnpm --filter @nexu-design/demo dev",
    "dev:demo:web": "pnpm --filter @nexu-design/demo dev:web",
    "dev:cloud-demo": "pnpm --filter @nexu-design/cloud-demo dev",
    "build": "pnpm build:storybook",
    "build:storybook": "pnpm --filter @nexu-design/storybook build-storybook",
    "build:demo": "pnpm --filter @nexu-design/demo build",
    "build:cloud-demo": "pnpm --filter @nexu-design/cloud-demo build",
    "build:electron": "pnpm --filter @nexu-design/demo dist",
    "build:packages": "pnpm --filter @nexu-design/tokens build && pnpm --filter @nexu-design/ui-web build",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=main",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "biome:check": "biome check .",
    "check:interactive-typography": "node ./scripts/check-interactive-typography.mjs",
    "check:publishable-packages": "node ./scripts/check-publishable-packages.mjs",
    "knip": "knip --config knip.json",
    "knip:production": "knip --config knip.json --production",
    "pack:check": "pnpm --filter @nexu-design/tokens pack:check && pnpm --filter @nexu-design/ui-web pack:check",
    "release:check:tokens": "pnpm --filter @nexu-design/tokens pack:check",
    "release:check:ui-web": "pnpm --filter @nexu-design/tokens build && pnpm --filter @nexu-design/ui-web pack:check",
    "release:check": "pnpm check:publishable-packages && pnpm build:packages && pnpm typecheck && pnpm test && pnpm pack:check",
    "release": "pnpm check:publishable-packages && changeset publish",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "version:packages": "changeset version && pnpm install --lockfile-only",
    "lint": "pnpm -r lint",
    "clean": "rm -rf node_modules apps/storybook/node_modules apps/demo/node_modules packages/ui-web/node_modules packages/tokens/node_modules apps/storybook/storybook-static apps/demo/dist apps/demo/dist-electron apps/demo/release"
  }
}
