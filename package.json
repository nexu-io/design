{
  "name": "nexu-design",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  },
  "scripts": {
    "dev": "pnpm --filter @nexu-design/storybook storybook & pnpm --filter @nexu-design/demo dev & wait",
    "dev:storybook": "pnpm --filter @nexu-design/storybook storybook",
    "dev:demo": "pnpm --filter @nexu-design/demo dev",
    "dev:demo:web": "pnpm --filter @nexu-design/demo dev:web",
    "dev:cloud-demo": "pnpm --filter @nexu-design/cloud-demo dev",
    "build": "pnpm build:storybook",
    "build:storybook": "pnpm --filter @nexu-design/storybook build-storybook",
    "build:demo": "pnpm --filter @nexu-design/demo build",
    "build:cloud-demo": "pnpm --filter @nexu-design/cloud-demo build",
    "build:tauri": "pnpm --filter @nexu-design/demo tauri:build",
    "build:packages": "pnpm --filter @nexu-design/tokens build && pnpm --filter @nexu-design/ui-web build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "biome:check": "biome check .",
    "pack:check": "pnpm --filter @nexu-design/tokens pack:check && pnpm --filter @nexu-design/ui-web pack:check",
    "release:check": "pnpm build:packages && pnpm typecheck && pnpm test && pnpm pack:check",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "rm -rf node_modules apps/storybook/node_modules apps/demo/node_modules packages/ui-web/node_modules packages/tokens/node_modules apps/storybook/storybook-static apps/demo/dist"
  }
}
