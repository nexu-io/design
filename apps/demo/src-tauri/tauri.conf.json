{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nexu",
  "version": "0.1.0",
  "identifier": "dev.nexu.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5175",
    "beforeDevCommand": "pnpm run dev:web",
    "beforeBuildCommand": "tsc -b && vite build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Nexu",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 16, "y": 18 },
        "transparent": false,
        "backgroundColor": "#fafafa",
        "center": true,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
