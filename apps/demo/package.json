{
  "name": "@nexu-design/demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main/bootstrap.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "NEXU_DESKTOP_DISABLE_VITE_ELECTRON_STARTUP=1 vite",
    "build": "tsc -b && vite build",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:win": "pnpm build && electron-builder --win",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "preview": "vite preview",
    "check:parity": "node scripts/check-pixel-parity.mjs",
    "check:parity:all": "node scripts/check-pixel-parity.mjs --page workspace && node scripts/check-pixel-parity.mjs --page skills && node scripts/check-pixel-parity.mjs --page auth"
  },
  "dependencies": {
    "@nexu-design/demo-pages": "workspace:*",
    "@nexu-design/ui-web": "workspace:*",
    "@sentry/electron": "^7.10.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.34.5",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^37.2.5",
    "electron-builder": "^26.0.12",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "io.nexu.design.demo",
    "productName": "Nexu Demo",
    "directories": {
      "output": "release"
    },
    "files": ["dist/**/*", "dist-electron/**/*", "package.json"],
    "mac": {
      "icon": "src-tauri/icons/icon.icns",
      "target": ["dmg", "zip"],
      "artifactName": "nexu-demo-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "src-tauri/icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "nexu-demo-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false
    }
  }
}
