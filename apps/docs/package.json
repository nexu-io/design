{
  "name": "@nexu-design/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build && pnpm pages-output",
    "build:pages": "next build && pnpm pages-output",
    "docs:build": "pnpm build",
    "pages-output": "rm -rf storybook-static ../../out ../../storybook-static ../storybook/storybook-static && cp -R out storybook-static && cp -R out ../../out && cp -R out ../../storybook-static && cp -R out ../storybook/storybook-static",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@nexu-design/tokens": "workspace:*",
    "@nexu-design/ui-web": "workspace:*",
    "fumadocs-core": "^16.8.5",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "^16.8.5",
    "lucide-react": "^1.11.0",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.9.3"
  }
