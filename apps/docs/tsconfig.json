{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "incremental": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@nexu-design/tokens": ["../../packages/tokens/src/index.ts"],
      "@nexu-design/tokens/styles.css": ["../../packages/tokens/src/styles.css"],
      "@nexu-design/ui-web": ["../../packages/ui-web/src/index.ts"],
      "@nexu-design/ui-web/styles.css": ["../../packages/ui-web/src/styles.css"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    "**/*.mdx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
