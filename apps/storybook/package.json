{
  "name": "@nexu-design/storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "storybook:build": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "build": "pnpm storybook:build && pnpm pages-output",
    "pages:build": "pnpm build",
    "build:pages": "pnpm build",
    "build:storybook": "pnpm build",
    "pages-output": "rm -rf out dist .vercel/output/static ../../out ../../dist ../../storybook-static ../../.vercel/output/static && mkdir -p .vercel/output ../../.vercel/output && cp -R storybook-static out && cp -R storybook-static dist && cp -R storybook-static .vercel/output/static && cp -R storybook-static ../../out && cp -R storybook-static ../../dist && cp -R storybook-static ../../storybook-static && cp -R storybook-static ../../.vercel/output/static",
    "docs:build": "pnpm -w run docs:build",
    "build-storybook": "pnpm build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@nexu-design/tokens": "workspace:*",
    "@nexu-design/ui-web": "workspace:*",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@storybook/addon-docs": "9.1.20",
    "@storybook/react-vite": "9.1.20",
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "storybook": "9.1.20",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.8.3",
    "vite": "^6.3.6"
  }
}
