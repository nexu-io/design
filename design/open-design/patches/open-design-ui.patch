+/* ============================================================
+   Project shell — nexu-chat style 3-column layout
+   ============================================================ */
+.project-shell {
+  display: flex;
+  flex-direction: column;
+  height: 100vh;
+  background: var(--bg-muted);
+  overflow: hidden;
+}
+
+/* Horizontal panes row below the titlebar */
+.project-body {
+  display: grid;
+  gap: 0;
+  flex: 1;
+  min-height: 0;
+  padding: 0 14px 14px;
+  box-sizing: border-box;
+  overflow: hidden;
+  background: var(--bg-muted);
+}
+
+.project-resizer {
+  position: relative;
+  width: 4px;
+  min-width: 4px;
+  height: 100%;
+  cursor: col-resize;
+  border: 0;
+  padding: 0;
+  background: transparent;
+  border-radius: 999px;
+  align-self: stretch;
+}
+.project-resizer::before {
+  content: '';
+  position: absolute;
+  top: 12px;
+  bottom: 12px;
+  left: 50%;
+  width: 1px;
+  border-radius: 999px;
+  background: linear-gradient(
+    180deg,
+    transparent 0%,
+    rgba(20, 184, 166, 0.18) 18%,
+    rgba(20, 184, 166, 0.62) 50%,
+    rgba(20, 184, 166, 0.18) 82%,
+    transparent 100%
+  );
+  opacity: 0;
+  transform: translateX(-50%);
+  transition: opacity 120ms ease, width 120ms ease;
+}
+.project-resizer:hover::before,
+.project-resizer.dragging::before {
+  width: 2px;
+  opacity: 1;
+}
+body.project-resizing {
+  cursor: col-resize;
+  user-select: none;
+}
+
