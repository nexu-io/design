+}
+.project-status-title {
+  min-width: 0;
+  display: flex;
+  align-items: baseline;
+  gap: 8px;
+  font-size: 13px;
+  font-weight: 600;
+  color: var(--text);
+}
+.project-status-title span:last-child {
+  min-width: 0;
+  max-width: 220px;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+  font-size: 11px;
+  font-weight: 500;
+  color: var(--text-soft);
+}
+.project-status-scroll {
+  flex: 1;
+  min-height: 0;
+  overflow-y: auto;
+  padding: 18px;
+  display: flex;
+  flex-direction: column;
+  gap: 18px;
+}
+.project-status-group {
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+}
+.project-status-section {
+  font-size: 11px;
+  font-weight: 600;
+  color: var(--text-muted);
+}
+.project-status-row {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  align-items: center;
+  gap: 8px 12px;
+  padding: 11px 12px;
+  border: 1px solid var(--border);
+  border-radius: 8px;
+  background: var(--bg);
+}
+.project-status-row-main {
+  min-width: 0;
+  display: flex;
+  flex-direction: column;
+  gap: 2px;
+}
+.project-status-row-label {
+  min-width: 0;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+  font-size: 12.5px;
+  font-weight: 600;
+  color: var(--text);
+}
+.project-status-row-meta {
+  min-width: 0;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+  font-size: 11px;
+  color: var(--text-muted);
+}
+.project-status-row-state {
+  padding: 3px 8px;
+  border: 1px solid var(--border);
+  border-radius: 999px;
+  font-size: 10.5px;
+  font-weight: 600;
+  line-height: 1;
+  color: var(--text-muted);
+  background: var(--bg-panel);
+}
+.project-status-bar {
+  grid-column: 1 / -1;
+  height: 5px;
+  overflow: hidden;
+  border-radius: 999px;
+  background: var(--bg-subtle);
+}
+.project-status-bar-fill {
+  display: block;
+  height: 100%;
+  border-radius: inherit;
+  background: #353535;
+}
+.project-status-row[data-tone='active'] .project-status-bar-fill {
+  background: linear-gradient(90deg, #14b8a6 0%, #353535 100%);
+}
+.project-status-row[data-tone='done'] .project-status-bar-fill {
+  background: #14b8a6;
+}
+.project-status-row[data-tone='warn'] .project-status-bar-fill {
+  background: #f59e0b;
+}
+
+/* Inline status inside conv-sidebar */
+.conv-status-inline {
+  display: flex;
+  flex-direction: column;
+  padding: 8px 0 12px;
+  overflow-y: auto;
+  flex: 1;
+}
+.conv-status-section {
+  font-size: 10.5px;
+  font-weight: 600;
+  text-transform: uppercase;
+  letter-spacing: 0.07em;
+  color: var(--text-faint);
+  padding: 10px 14px 5px;
+}
+/* Scale down project-status-row for sidebar width */
+.conv-status-inline .project-status-row {
+  margin: 0 10px 6px;
+  padding: 10px 12px;
+}
+.conv-status-inline .project-status-row-label {
+  font-size: 12.5px;
+}
+.conv-status-inline .project-status-row-meta {
+  font-size: 11px;
+}
+.conv-status-inline .project-status-row-state {
+  font-size: 10.5px;
+  padding: 2px 7px;
+}
