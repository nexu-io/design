+        <span className="text-[9px]">✦</span>
+        无限使用
+      </span>
+    );
+  }
+  return (
+    <span className="inline-flex items-center px-1.5 py-0.5 rounded-[4px] bg-[var(--color-surface-3)] text-text-secondary text-[10px] font-medium leading-none whitespace-nowrap">
+      套餐额度内
+    </span>
+  );
+}
+
+// ── Main component ─────────────────────────────────────────────────────────────
