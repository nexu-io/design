+++ b/design-system/src/components/openclaw/SkillMarketplaceCard.tsx
@@ -0,0 +1,72 @@
+import type { ElementType, ReactNode } from 'react';
+import { cn } from '@/lib/utils';
+
+export type SkillMarketplaceCardProps = {
+  name: string;
+  desc: string;
+  categoryLabel?: string | null;
+  logo?: string;
+  /** Fallback when logo missing or broken — matches SkillDef.icon (lucide-style) */
+  icon: ElementType<{ size?: number; className?: string }>;
+  /** Installed + disabled — Design Spec: opacity-55 */
+  dimmed?: boolean;
+  footer: ReactNode;
+  className?: string;
+};
+
+/**
+ * Skills marketplace / Yours grid card — Tailwind implementation of
+ * "Skill Card — Design Spec" in design-system/src/index.css
+ */
+export function SkillMarketplaceCard({
+  name,
+  desc,
+  categoryLabel,
+  logo,
+  icon: Icon,
+  dimmed,
+  footer,
+  className,
+}: SkillMarketplaceCardProps) {
+  return (
+    <div
+      className={cn(
+        'card flex flex-col p-4',
+        dimmed && 'opacity-55',
+        className,
+      )}
+    >
+      <div className="flex items-center gap-3 mb-2">
+        <div className="flex h-9 w-9 shrink-0 items-center justify-center overflow-hidden rounded-[10px] border border-border bg-white">
+          {logo ? (
+            <>
+              <img
+                src={logo}
+                alt=""
+                className="h-[18px] w-[18px] object-contain"
+                onError={(e) => {
+                  e.currentTarget.style.display = 'none';
+                  const fb = e.currentTarget.nextElementSibling as HTMLElement | null;
+                  if (fb) fb.style.display = 'flex';
+                }}
+              />
+              <div className="hidden h-full w-full items-center justify-center">
+                <Icon size={18} className="text-text-secondary" />
+              </div>
+            </>
+          ) : (
+            <Icon size={18} className="text-text-secondary" />
+          )}
+        </div>
+        <div className="min-w-0 flex-1">
+          <div className="truncate text-[13px] font-semibold text-text-heading">{name}</div>
+          {categoryLabel != null && categoryLabel !== '' && (
+            <span className="text-[11px] text-text-muted">{categoryLabel}</span>
+          )}
+        </div>
+      </div>
+      <p className="mb-3 line-clamp-2 text-[12px] leading-[1.5] text-text-tertiary">{desc}</p>
+      <div className="mt-auto flex items-center justify-between">{footer}</div>
+    </div>
+  );
+}

