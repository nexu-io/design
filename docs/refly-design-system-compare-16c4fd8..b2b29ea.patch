+.markdown-preview code { font-family: 'SF Mono', 'Fira Code', monospace; font-size: 0.88em; padding: 0.15em 0.35em; background: var(--color-surface-3); border-radius: 3px; color: var(--color-text-primary); }
+.markdown-preview pre { margin: 0.5em 0; padding: 0.8em 1em; background: var(--color-surface-2); border: 1px solid var(--color-border); border-radius: 6px; overflow-x: auto; }
+.markdown-preview pre code { padding: 0; background: none; font-size: 0.85em; line-height: 1.5; }
+.markdown-preview table { width: 100%; margin: 0.5em 0; border-collapse: collapse; font-size: 0.9em; }
+.markdown-preview th, .markdown-preview td { padding: 0.4em 0.6em; border: 1px solid var(--color-border); text-align: left; }
+.markdown-preview th { background: var(--color-surface-2); font-weight: 600; font-size: 0.88em; color: var(--color-text-secondary); }
+.markdown-preview hr { border: none; border-top: 1px solid var(--color-border); margin: 1em 0; }
+.markdown-preview input[type="checkbox"] { margin-right: 0.4em; accent-color: var(--color-accent); }
+
+.markdown-preview-compact { font-size: 11px; line-height: 1.6; }
+.markdown-preview-compact h1 { font-size: 1.2em; }
+.markdown-preview-compact h2 { font-size: 1.1em; }
+.markdown-preview-compact pre { padding: 0.5em 0.7em; }
+.markdown-preview-compact table { font-size: 0.85em; }

