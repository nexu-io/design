+  description?: React.ReactNode
+  actions?: React.ReactNode
+  spacing?: 'sm' | 'md' | 'lg'
+  className?: string
+}
+
+const spacingMap = {
+  sm: 'mb-6',
+  md: 'mb-8',
+  lg: 'mb-10',
+} as const
+
+export function PageHeader({
+  title,
+  description,
+  actions,
+  spacing = 'lg',
+  className,
+}: PageHeaderProps) {
+  const hasActions = actions != null
+
+  return (
+    <div
+      className={`${hasActions ? 'flex items-center justify-between' : ''} ${spacingMap[spacing]} ${className ?? ''}`}
+    >
+      <div>
+        <h1 className="heading-page">{title}</h1>
+        {description && <p className="heading-page-desc">{description}</p>}
+      </div>
+      {hasActions && <div className="flex items-center gap-2 shrink-0">{actions}</div>}
+    </div>
+  )
+}

