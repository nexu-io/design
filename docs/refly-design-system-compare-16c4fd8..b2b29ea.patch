+
+type Status = 'live' | 'building' | 'failed' | 'idle' | 'online' | 'offline' | 'busy' | 'away'
+type Size = 'xs' | 'sm' | 'md' | 'lg'
+
+interface StatusDotProps {
+  status: Status
+  size?: Size
+  pulse?: boolean
+  className?: string
+}
+
+const colorMap: Record<Status, string> = {
+  live: 'bg-success',
+  online: 'bg-success',
+  building: 'bg-warning',
+  idle: 'bg-warning',
+  busy: 'bg-warning',
+  failed: 'bg-danger',
+  offline: 'bg-surface-4',
+  away: 'bg-text-muted',
+}
+
+const sizeMap: Record<Size, string> = {
+  xs: 'w-1 h-1',
+  sm: 'w-1.5 h-1.5',
+  md: 'w-2 h-2',
+  lg: 'w-2.5 h-2.5',
+}
+
+export function StatusDot({
+  status,
+  size = 'sm',
+  pulse,
+  className,
+}: StatusDotProps) {
+  return (
+    <span
+      className={`inline-block rounded-full shrink-0 ${sizeMap[size]} ${colorMap[status]} ${pulse ? 'animate-pulse' : ''} ${className ?? ''}`}
+    />
+  )
+}

