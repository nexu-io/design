diff --git a/design-system/src/components/ui/filter-pills.tsx b/design-system/src/components/ui/filter-pills.tsx
new file mode 100644
index 0000000..85aca2a
--- /dev/null
+++ b/design-system/src/components/ui/filter-pills.tsx
@@ -0,0 +1,78 @@
+import * as React from 'react'
+
+type FilterPillItem = {
+  id: string
+  label: string
+  count?: number
+  icon?: React.ComponentType<{ size?: number }>
+  emoji?: string
+}
+
+type Variant = 'pill' | 'segment'
+
+interface FilterPillsProps {
+  items: FilterPillItem[]
+  value: string
+  onChange: (id: string) => void
+  variant?: Variant
+  className?: string
+  size?: 'sm' | 'md'
+}
+
+const pillStyles = {
+  active: 'bg-[var(--color-accent)] text-white',
+  inactive: 'border border-border bg-surface-1 text-text-secondary hover:text-text-primary hover:border-border-hover',
+} as const
+
+const segmentStyles = {
+  active: 'bg-white text-text-primary shadow-[var(--shadow-rest)]',
+  inactive: 'text-text-secondary hover:text-text-primary',
+} as const
+
+const sizeMap = {
+  sm: { button: 'h-7 px-3 text-[12px]', count: 'text-[11px]', container: 'gap-2' },
+  md: { button: 'h-8 px-4 text-[13px]', count: 'text-[12px]', container: 'gap-1' },
+} as const
+
+export function FilterPills({
+  items,
+  value,
+  onChange,
+  variant = 'pill',
+  className,
+  size = 'sm',
+}: FilterPillsProps) {
+  const styles = variant === 'segment' ? segmentStyles : pillStyles
+  const s = sizeMap[size]
+
+  const wrapperCn = variant === 'segment'
+    ? `inline-flex items-center ${s.container} p-1 rounded-full bg-surface-2`
+    : `flex items-center ${s.container} flex-wrap`
+
+  return (
+    <div className={`${wrapperCn} ${className ?? ''}`}>
+      {items.map((item) => {
+        const active = value === item.id
+        const Icon = item.icon
+        return (
+          <button
+            key={item.id}
+            onClick={() => onChange(item.id)}
+            className={`shrink-0 inline-flex items-center justify-center rounded-full ${s.button} leading-none font-medium transition-all ${
+              active ? styles.active : styles.inactive
+            }`}
+          >
+            {Icon && <Icon size={14} />}
+            {item.emoji && <span className="text-[11px]">{item.emoji}</span>}
+            {item.label}
+            {item.count != null && (
+              <span className={`ml-1 tabular-nums ${s.count} ${active ? 'opacity-80' : 'opacity-50'}`}>
+                {item.count}
+              </span>
+            )}
+          </button>
+        )
+      })}
+    </div>
+  )
+}

diff --git a/design-system/src/components/ui/nav-item.tsx b/design-system/src/components/ui/nav-item.tsx
