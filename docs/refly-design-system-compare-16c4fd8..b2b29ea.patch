@@ -0,0 +1,38 @@
+import * as React from 'react'
+
+interface NavItemProps {
+  icon?: React.ReactNode
+  label: string
+  active?: boolean
+  onClick?: () => void
+  trailing?: React.ReactNode
+  density?: 'default' | 'compact'
+  className?: string
+  children?: React.ReactNode
+}
+
+export function NavItem({
+  icon,
+  label,
+  active,
+  onClick,
+  trailing,
+  density = 'default',
+  className,
+  children,
+}: NavItemProps) {
+  const py = density === 'compact' ? 'py-1.5' : 'py-2'
+
+  return (
+    <button
+      onClick={onClick}
+      className={`flex items-center gap-2.5 w-full rounded-[var(--radius-6)] text-[13px] transition-colors cursor-pointer px-3 ${py} ${
+        active ? 'nav-item-active' : 'nav-item'
+      } ${className ?? ''}`}
+    >
+      {icon}
+      {children ?? <span className={density === 'compact' ? 'truncate text-[12px]' : ''}>{label}</span>}
+      {trailing && <span className="ml-auto">{trailing}</span>}
+    </button>
+  )
+}

